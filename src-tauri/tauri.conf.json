{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "CloudPivot IMS",
  "version": "0.1.4",
  "identifier": "com.cloudpivot.ims",
  "build": {
    "frontendDist": "../out",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "云枢 (CloudPivot IMS)",
        "width": 1440,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 768,
        "resizable": true,
        "dragDropEnabled": false,
        "fullscreen": false,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEYwREQ3NkMyMDlDODQxMkMKUldRc1FjZ0p3bmJkOElXc2FxeUdoZDRpdk1FWjV0VnRrVm1ZdURRR0I0cnBQajJGUGE3ZFhIanoK",
      "endpoints": [
        "https://github.com/kurisu994/CloudPivot/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
